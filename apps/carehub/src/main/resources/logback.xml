<?xml version="1.0" encoding="UTF-8"?>
<configuration>

  <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
    <encoder class="net.logstash.logback.encoder.LoggingEventCompositeJsonEncoder">
      <providers>
        <timestamp/>
        <logLevel/>
        <threadName/>
        <loggerName/>
        <message/>
        <!-- Captures: trace_id, span_id, trace_flags (OTel agent)
                       profile, service, method, path (MDCFilter) -->
        <mdc/>
        <jsonFields>
          <field name="war" value="carehub"/>
        </jsonFields>
      </providers>
    </encoder>
  </appender>

  <!-- Suppress noisy Tomcat startup scan warnings -->
  <logger name="org.apache.jasper.servlet.TldScanner" level="ERROR"/>
  <logger name="org.apache.catalina"                  level="WARN"/>
  <logger name="org.apache.coyote"                    level="WARN"/>

  <!-- Application loggers -->
  <logger name="com.enterprise.platform" level="INFO"/>

  <root level="INFO">
    <appender-ref ref="CONSOLE"/>
  </root>

</configuration>
